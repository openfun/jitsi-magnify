{
  "name": "sandbox",
  "private": true,
  "license": "MIT",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test-watch": "vitest --ui",
    "coverage": "vitest run --coverage",
    "compile-translations": "../packages/core/i18n/compile-translations.cjs ./i18n/locales/*.json",
    "extract-translations": "formatjs extract './**/*.ts*' --ignore ./node_modules --ignore './**/*.d.ts' --ignore './**/*.stories.ts*' --out-file './i18n/frontend.json' --id-interpolation-pattern '[sha512:contenthash:base64:6]' --format crowdin",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check src ",
    "format:write": "prettier --write src",
    "build-theme": "cunningham -g css,ts -o src"
  },
  "dependencies": {
    "@jitsi/react-sdk": "1.4.0",
    "@openfun/cunningham-react": "2.6.0",
    "@openfun/jitsi-magnify": "*",
    "@tanstack/react-query": "5.28.9",
    "@tanstack/react-query-devtools": "5.28.10",
    "@types/styled-components": "5.1.34",
    "axios": "1.6.8",
    "grommet": "2.36.1",
    "grommet-icons": "4.12.1",
    "polished": "4.3.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-intl": "6.6.4",
    "react-router-dom": "6.22.3",
    "react-scripts": "5.0.1",
    "stream": "npm:stream-browserify",
    "stream-browserify": "3.0.0",
    "styled-components": "5.3.11",
    "validator": "13.11.0",
    "web-vitals": "3.5.2"
  },
  "devDependencies": {
    "@lib/eslint-config": "*",
    "@lib/typescript-configs": "*",
    "@testing-library/jest-dom": "6.4.2",
    "@testing-library/react": "13.0.0",
    "@testing-library/user-event": "14.5.2",
    "@types/jest": "29.5.12",
    "@types/node": "20.11.30",
    "@types/react": "18.2.73",
    "@types/react-dom": "18.2.22",
    "@typescript-eslint/eslint-plugin": "7.4.0",
    "@typescript-eslint/parser": "7.4.0",
    "@vitejs/plugin-react": "4.2.1",
    "@vitest/ui": "1.4.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-import-resolver-typescript": "3.6.1",
    "eslint-plugin-compat": "4.2.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-jsx-a11y": "6.8.0",
    "eslint-plugin-prettier": "5.1.3",
    "eslint-plugin-react": "7.34.1",
    "jsdom": "24.0.0",
    "msw": "2.2.13",
    "prettier": "3.2.5",
    "ts-jest": "29.1.2",
    "typescript": "5.4.3",
    "vite": "5.2.6",
    "vite-tsconfig-paths": "4.3.2",
    "vitest": "1.4.0",
    "vitest-dom": "0.1.1"
  }
}
